{
    "env": {
        "browser": true,
        "es2021": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "plugins": ["prettier"],
    "rules": {
        "no-extra-semi": "off",
        "no-mixed-spaces-and-tabs": "off",
        "prettier/prettier": "error"
    }
}
