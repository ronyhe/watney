{
    "env": {
        "browser": true,
        "es2021": true,
        "jest/globals": true
    },
    "extends": ["plugin:jest/recommended", "plugin:jest/style", "eslint:recommended"],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "plugins": ["jest", "prettier"],
    "rules": {
        "no-extra-semi": "off",
        "no-mixed-spaces-and-tabs": "off",
        "prettier/prettier": "error"
    }
}
